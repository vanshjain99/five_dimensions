{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/index.php",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|robots.txt|sitemap.xml|llms.txt|pricing.md).*)",
      "destination": "/index.html"
    }
  ]
}
